{
  "name": "hyperactive-pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "vite build --base=./",
    "build:deploy": "vite build --base=/HIBRIDCLUB/",
    "preview": "vite preview",
    "android:init": "npm install @capacitor/core @capacitor/cli @capacitor/android @capacitor/app --save-dev && npx cap add android",
    "android:sync": "npm run build:android && npx cap sync android",
    "android:open": "npm run android:sync && npx cap open android",
    "android:debug": "npm run android:sync && cd android && gradlew assembleDebug",
    "predeploy": "npm run build:deploy",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "lucide-react": "^1.8.0",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
